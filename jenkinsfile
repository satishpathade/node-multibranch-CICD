pipeline {
    agent any

    environment {
        SSH_CRED = 'multi-node-key'
        SERVER_IP = '65.2.187.185'
        REMOTE_USER = 'ubuntu'
        APP_DIR = '/home/ubuntu/nodeapp'
        APP_NAME = 'node-app'
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(credentials: ["${SSH_CRED}"]) {
                    sh '''
                    ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} "mkdir -p ${APP_DIR}"
                    scp -r src package.json ${REMOTE_USER}@${SERVER_IP}:${APP_DIR}/
                    '''
                }
            }
        }

        stage('Start Application') {
            steps {
                sshagent(credentials: ["${SSH_CRED}"]) {
                    sh '''
                    ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} '
                        cd /home/ubuntu/nodeapp

                        npm install

                        pm2 delete node-app || true
                        pm2 start src/server.js --name node-app
                        pm2 save
                    '
                    '''
                }
            }
        }
    }
}