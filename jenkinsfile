pipeline {
    agent any

    environment {
        SSH_CRED = 'multi-node-key'
        SERVER_IP = '65.2.187.185'
        REMOTE_USER = 'ubuntu'
        APP_DIR = '/home/ubuntu/nodeapp'
        APP_NAME = 'node-app'
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'npm test'
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(credentials: ["${SSH_CRED}"]) {
                    sh '''
                    ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} "mkdir -p ${APP_DIR}"
                    scp -r src package.json ${REMOTE_USER}@${SERVER_IP}:${APP_DIR}/
                    '''
                }
            }
        }

        stage('Start Application') {
            steps {
                sshagent(credentials: ["${SSH_CRED}"]) {
                    sh '''
                    ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} '
                        sudo apt update
                        sudo apt install nodejs npm -y
                        sudo npm install -g pm2

                        cd ${APP_DIR}

                        npm install

                        pm2 delete ${APP_NAME} || true
                        pm2 start src/server.js --name ${APP_NAME}
                        pm2 save
                    '
                    '''
                }
            }
        }
    }
}